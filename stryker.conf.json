{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "reporters": ["clear-text", "progress", "html"],
  "testRunner": "mocha",
  "mochaOptions": {
    "require": ["tsx/cjs"],
    "extension": ["ts"],
    "spec": ["test/unit/**/*.test.ts"]
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/utils/angle-converter.ts",
    "src/utils/angular-paths.ts",
    "src/utils/buffer-sql-builder.ts",
    "src/utils/concurrency-limiter.ts",
    "src/utils/duration-parser.ts",
    "src/utils/geo-calculator.ts",
    "src/utils/gpx-parser.ts",
    "src/utils/hive-path-builder.ts",
    "src/utils/lru-cache.ts",
    "src/utils/path-filters.ts",
    "src/utils/path-helpers.ts",
    "src/utils/retention-rules.ts",
    "src/utils/spatial-queries.ts",
    "src/utils/sql-escape.ts",
    "src/utils/type-detector.ts",
    "src/claude-models.ts"
  ],
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 0
  },
  "disableTypeChecks": true,
  "ignorePatterns": [
    "coverage",
    "dist",
    "reports",
    ".stryker-tmp",
    "public",
    "devdocs",
    "tests",
    "scripts",
    "*.tgz"
  ],
  "timeoutMS": 30000
}
